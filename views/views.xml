<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Views de Tipos de reserva --> 
  <record id="maya_booking.view_booking_type_kanban" model="ir.ui.view">
    <field name="name">maya_booking.booking_type.kanban</field>
    <field name="model">maya_booking.booking_type</field>
    <field name="arch" type="xml">
      <kanban class="o_kanban_ungrouped" action="action_open_timeline" type="object">
        <field name="name"/>
        <templates>
          <t t-name="card">
            <div class="oe_kanban_global_click w-100 d-flex align-items-center justify-content-between p-3 mb-1">
              
              <div class="d-flex align-items-center">
                <span class="fw-bold fs-5">
                  <field name="name"/>
                </span>
              </div>

              <div class="d-flex gap-2">
                <button class="btn btn-sm btn-secondary" title="Publicar">Publicar</button>
                <button type="open" class="btn btn-sm btn-primary" title="Editar">Editar</button>
              </div>

            </div>
          </t>
        </templates>
      </kanban>
    </field>
</record>

<record id="maya_booking.view_booking_type_form" model="ir.ui.view">
  <field name="name">maya_booking.booking_type.form</field>
    <field name="model">maya_booking.booking_type</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <div class="oe_title">
            <h1><field name="name" placeholder="Nombre del Tipo..."/></h1>
          </div>
          <group>
            <group>
            <field name="description"/>
            <field name="duration"/>
            <!-- <field name="resource_type"/> -->
            <field name="resource_type" widget="radio" options="{'horizontal': true}"/>
            </group>
          </group>
          <notebook>
            <page string="Recursos Asociados">
            <!-- <field name="resource_ids" widget="many2many"/> -->
              <field name="resource_ids">
               <list editable="bottom">
                  <field name="resource_name"/>
                  <field name="reservable_model" column_invisible="False"/>
                  <field name="reservable_id" column_invisible="False"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record model="ir.ui.view" id="maya_booking.view_place_form_inherit">
    <field name="name">Formulario espacios. Añade reservas</field>
    <field name="model">maya_core.place</field>
    <field name="inherit_id" ref="maya_core.view_place_form"/>
    <field name="arch" type="xml">
      <xpath expr="/form/notebook/page[1]" position="after">
        <page string = "Reservas">
          <group>
            <field name="bookable" widget="boolean_toggle"/>
            <field name="num_max_session_consecutive"/>
            <field name="max_days_in_advance"/>
            <field name="booking_limit_date"/>
          </group>
        </page>
      </xpath>
    </field>
  </record>

    <record id="view_booking_form" model="ir.ui.view">
        <field name="name">maya_booking.booking.form</field>
        <field name="model">maya_booking.booking</field>
        <field name="arch" type="xml">
            <form string="Reserva">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Motivo / Descripción"/>
                        <h1>
                            <field name="name" placeholder="Ej: Reunión de departamento..." required="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Detalles del Recurso">
                           <!--  <field name="resource_id" options="{'no_create': True}"/> -->
                            <field name="user_id"/>
                        </group>
                        <group string="Selección de Horario">
                            <field name="booking_date"/>
                            <field name="available_schedule_ids" invisible="1"/>
                            <field name="schedule_id" options="{'no_create': True, 'no_open': True}" placeholder="Seleccione una sesión..."/>
                            <field name="session_count"/>
                            
                            <field name="date_start" force_save="1" readonly="1"/>
                            <field name="date_stop" force_save="1" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="maya_booking.view_booking_timeline" model="ir.ui.view">
      <field name="name">maya_booking.booking.timeline</field>
      <field name="model">maya_booking.booking</field>
       <!-- default_group_by="resource_id" -->
      <field name="arch" type="xml">
        <timeline date_start="date_start" 
                    date_stop="date_stop" 
                   
                    event_open_popup="true"
                    zoomKey="ctrlKey"
                    mode="week"
                    colors="#FF7F7F: user_id != false;"> 
            
          <field name="name"/>
        <!--   <field name="resource_id"/> -->
          <field name="user_id"/>

          <templates>
            <t t-name="timeline-item">
              <div class="o_timeline_item_content" style="padding: 2px;">
                  <t t-esc="(record.user_id ? record.user_id[1] : 'Sistema') + ' - ' + record.name"/>
              </div>
            </t>
          </templates>
        </timeline>
      </field>
    </record>

    <record id="maya_booking.action_booking_type" model="ir.actions.act_window">
      <field name="name">Tipos de reserva</field>
      <field name="res_model">maya_booking.booking_type</field>
      <field name="view_mode">kanban,form</field>
    </record>

    <menuitem id="menu_maya_booking_root" name="Maya | Booking" sequence="10"/>

    <menuitem id="menu_booking_type" name="Tipos de Reserva" parent="menu_maya_booking_root" action="maya_booking.action_booking_type" sequence="10"/>

</odoo>